# Edge-function secrets — set these on the NEW Showrunner Supabase project with:
#   supabase secrets set NAME=value
# NEVER commit the real .env. SUPABASE_URL / SERVICE_ROLE are auto-injected into
# deployed functions, but set them for local `supabase functions serve`.

# --- Phase 1 (needed now) ---
ANTHROPIC_API_KEY=          # Showrunner's OWN Claude key (own billing, not APN's)
ANTHROPIC_MODEL=claude-sonnet-5   # optional; breakdown/prompt model
GEMINI_API_KEY=             # Nano Banana (Gemini image) for reference sheets
NANO_BANANA_MODEL=gemini-2.5-flash-image   # optional override
RENDER_MODE=prep            # 'prep' (manual Seedance UI) until Spike H; then 'api'
HIGGSFIELD_API_KEY=         # only once RENDER_MODE=api is implemented

# --- Phase 2 (later: publishing) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# META_APP_ID=
# META_APP_SECRET=
# WHATSAPP_TOKEN=
